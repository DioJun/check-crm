generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "linux-musl"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  createdAt DateTime @default(now())
}

model Lead {
  id              String   @id @default(uuid())
  nome            String
  telefone        String?
  cidade          String?
  servico         String?
  status          String   @default("novo")
  origem          String?
  dataEntrada     DateTime @default(now())
  ultimaInteracao DateTime?
  avaliacao       String?
  reviews         String?
  temWhatsapp     Boolean?
  temSite         Boolean?
  site            String?
  interacoes      Interacao[]
}

model Interacao {
  id       String   @id @default(uuid())
  leadId   String
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tipo     String   @default("mensagem")
  conteudo String
  data     DateTime @default(now())
}
