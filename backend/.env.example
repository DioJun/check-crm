# Supabase PostgreSQL -- Session Pooler (porta 5432)
# Use a mesma URL para DATABASE_URL e DIRECT_URL
# Obtenha em: https://supabase.com > Project Settings > Database > Connection string > Session mode
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# JWT -- string longa e aleatoria (use qualquer gerador de senha)
JWT_SECRET="troque-por-uma-chave-secreta-forte-aqui"

# Porta local
PORT=3001

# URL do frontend (para CORS em producao -- ex: https://meu-crm.vercel.app)
CORS_ORIGIN=""

# Gemini API key (opcional) -- https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
