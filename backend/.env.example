# Supabase PostgreSQL -- Transaction pooler (porta 6543)
# Obtenha em: https://supabase.com > Project Settings > Database > Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# JWT -- string longa e aleatoria
JWT_SECRET="troque-por-uma-chave-secreta-forte-aqui"

# Porta local
PORT=3001

# Origins permitidos alem de localhost (ex: https://meu-crm.vercel.app)
ALLOWED_ORIGINS=""

# Gemini API key (opcional) -- https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
